# Root-level files that should stay local.
/.env
/.env.*
!/.env.example

# The Laravel application lives in /src.
/src/.env
/src/.env.*
!/src/.env.example
/src/auth.json
/src/.phpactor.json
/src/.phpunit.cache
/src/.phpunit.result.cache
/src/_ide_helper.php

# Composer / PHP dependencies.
/src/vendor/

# Node / Vite dependencies and build output.
/src/node_modules/
/src/public/build/
/src/public/fonts-manifest.dev.json
/src/public/hot
/src/public/storage
npm-debug.log
yarn-error.log

# Laravel runtime files.
/src/storage/*.key
/src/storage/pail
*.log

# Local editor and tool state.
/.codex/
/.cursor/
/.fleet/
/.idea/
/.nova/
/.vscode/
/.zed
/src/.codex/
/src/.cursor/
/src/.fleet/
/src/.idea/
/src/.nova/
/src/.vscode/
/src/.zed

# OS / local machine files.
.DS_Store
Thumbs.db

# Homestead.
/src/Homestead.json
/src/Homestead.yaml

# Root-level generated dependencies, caches, and build artifacts.
/node_modules/
/vendor/
/bootstrap/cache/
/database/*.sqlite
/public/build/
/storage/framework/
